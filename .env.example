# SECRET: do not commit real values. In production inject from a secrets manager.
# MongoDB URI; if it includes user:password it is sensitive. See docs/SECRETS.md
# MONGO_URI=mongodb://<user>:<password>@<host>/<db>

# Optional: base URL for breb service / mock (default: http://localhost:9112)
# For Node mock: omit or use http://localhost:9112
# For breb-mock-api (second API): http://localhost:9112
# For Postman Mock: the URL Postman gives you
# BREB_BASE_URL=http://localhost:9112


# /Users/juanbolanos/Downloads/mongodb-macos-aarch64--8.2.5/bin
# ./mongod --dbpath ~/mongodb/data

# Mongo. Locally without auth can be mongodb://localhost:27017/practice-project
# In production use URI with credentials from secrets (docs/SECRETS.md)
MONGO_URI=mongodb://localhost:27017/practice-project

# Redis (in Docker: host=redis, port=6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# Idempotency
IDEMPOTENCY_KEY_PREFIX=idempotency
IDEMPOTENCY_TTL_SECONDS=86400

# Optional: Breb mock
BREB_BASE_URL=http://localhost:3001/transfer

# BREB circuit breaker (required; no defaults in code)
BREB_CIRCUIT_TIMEOUT_MS=15000
BREB_CIRCUIT_ERROR_THRESHOLD_PERCENT=65
BREB_CIRCUIT_RESET_TIMEOUT_MS=30000
BREB_CIRCUIT_VOLUME_THRESHOLD=10

# Transfer fee: whole-number percentage (1 = 1%). Required.
TRANSFER_FEE_RATE_COP=1
TRANSFER_FEE_RATE_USD=2
