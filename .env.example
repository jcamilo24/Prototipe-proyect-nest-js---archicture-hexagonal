# Opcional: URI de MongoDB (por defecto: mongodb://localhost:27017/practice-project)
# MONGO_URI=mongodb://localhost:27017/practice-project

# Opcional: URL base del servicio breb / mock (por defecto: http://localhost:9112)
# Para mock en Node: no definir o http://localhost:9112
# Para breb-mock-api (segunda API): http://localhost:9112
# Para Postman Mock: la URL que te da Postman
# BREB_BASE_URL=http://localhost:9112


# /Users/juanbolanos/Downloads/mongodb-macos-aarch64--8.2.5/bin
# ./mongod --dbpath ~/mongodb/data

# Mongo (en Docker: mongodb://mongo:27017/practice-project)
MONGO_URI=mongodb://localhost:27017/practice-project

# Redis (en Docker: host=redis, port=6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# Idempotencia
IDEMPOTENCY_KEY_PREFIX=idempotency
IDEMPOTENCY_TTL_SECONDS=86400

# Opcional: mock Breb
BREB_BASE_URL=http://localhost:3001/transfer