# SECRET: no commitear valor real. En producción inyectar desde gestor de secrets.
# URI de MongoDB; si incluye user:password es sensible. Ver docs/SECRETS.md
# MONGO_URI=mongodb://<user>:<password>@<host>/<db>

# Opcional: URL base del servicio breb / mock (por defecto: http://localhost:9112)
# Para mock en Node: no definir o http://localhost:9112
# Para breb-mock-api (segunda API): http://localhost:9112
# Para Postman Mock: la URL que te da Postman
# BREB_BASE_URL=http://localhost:9112


# /Users/juanbolanos/Downloads/mongodb-macos-aarch64--8.2.5/bin
# ./mongod --dbpath ~/mongodb/data

# Mongo. En local sin auth puede ser mongodb://localhost:27017/practice-project
# En producción usar URI con credenciales desde secrets (docs/SECRETS.md)
MONGO_URI=mongodb://localhost:27017/practice-project

# Redis (en Docker: host=redis, port=6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# Idempotencia
IDEMPOTENCY_KEY_PREFIX=idempotency
IDEMPOTENCY_TTL_SECONDS=86400

# Opcional: mock Breb
BREB_BASE_URL=http://localhost:3001/transfer

# Circuit breaker BREB (requeridas; sin defaults en código)
BREB_CIRCUIT_TIMEOUT_MS=15000
BREB_CIRCUIT_ERROR_THRESHOLD_PERCENT=65
BREB_CIRCUIT_RESET_TIMEOUT_MS=30000
BREB_CIRCUIT_VOLUME_THRESHOLD=10